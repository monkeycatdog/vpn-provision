# Skeleton OpenVPN client config.
# Copy to secrets/corporate.ovpn and fill in the values provided by your corporate IT.
# The accompanying credentials file (if any) belongs in secrets/corporate.auth.

client
dev tun
proto udp

# Cipher must match your server
cipher BF-CBC

# Replace with the hostname/IP and port of your OpenVPN server
remote vpn.example.com 1194

resolv-retry infinite
nobind
persist-key
persist-tun

# Paste your CA certificate between the tags below
<ca>
-----BEGIN CERTIFICATE-----
REPLACE_WITH_YOUR_CA_CERTIFICATE
-----END CERTIFICATE-----
</ca>

# Paste your client certificate between the tags below
<cert>
-----BEGIN CERTIFICATE-----
REPLACE_WITH_YOUR_CLIENT_CERTIFICATE
-----END CERTIFICATE-----
</cert>

# Paste your client private key between the tags below
<key>
-----BEGIN PRIVATE KEY-----
REPLACE_WITH_YOUR_CLIENT_PRIVATE_KEY
-----END PRIVATE KEY-----
</key>

# Optional TLS-auth static key
# <tls-auth>
# -----BEGIN OpenVPN Static key V1-----
# REPLACE_WITH_YOUR_TLS_AUTH_KEY
# -----END OpenVPN Static key V1-----
# </tls-auth>
# key-direction 1

# If your server requires username/password, uncomment and point at secrets/corporate.auth
# auth-user-pass /etc/openvpn/client/corporate.auth

remote-cert-tls server
verb 3
