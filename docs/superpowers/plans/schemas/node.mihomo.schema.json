{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TriState mihomo node",
  "type": "object",
  "required": ["host", "ssh_user", "ssh_port", "install_dir", "listen_port",
               "hysteria2", "outline", "openvpn_corp"],
  "properties": {
    "host":         {"type": "string"},
    "ssh_user":     {"type": "string"},
    "ssh_port":     {"type": "integer"},
    "install_dir":  {"type": "string"},
    "listen_port":  {"type": "integer", "minimum": 1, "maximum": 65535},
    "hysteria2": {
      "type": "object",
      "required": ["cert_pem", "key_pem", "cert_fingerprint_sha256"],
      "properties": {
        "cert_pem":                {"type": "string"},
        "key_pem":                 {"type": "string"},
        "cert_fingerprint_sha256": {"type": "string"}
      }
    },
    "outline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "address", "port", "method", "password"],
        "properties": {
          "name":     {"type": "string"},
          "address":  {"type": "string"},
          "port":     {"type": "integer"},
          "method":   {"type": "string"},
          "password": {"type": "string"}
        }
      }
    },
    "openvpn_corp": {
      "type": "object",
      "required": ["server", "port", "proto", "ca_pem"],
      "properties": {
        "server":       {"type": "string"},
        "port":         {"type": "integer"},
        "proto":        {"type": "string", "enum": ["udp", "tcp"]},
        "username":     {"type": "string"},
        "password":     {"type": "string"},
        "ca_pem":       {"type": "string"},
        "tls_crypt_pem":{"type": "string"},
        "cert_pem":     {"type": "string"},
        "key_pem":      {"type": "string"},
        "cipher":       {"type": "string"},
        "auth":         {"type": "string"}
      },
      "dependencies": {
        "username": ["password"],
        "password": ["username"],
        "cert_pem": ["key_pem"],
        "key_pem":  ["cert_pem"]
      }
    }
  }
}
