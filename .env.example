# Copy to .env and fill in. Do not commit .env.
#
#   cp .env.example .env
#
# All TRISTATE_* variables are read by `just` recipes. Scripts can still be run
# manually with ./scripts/... if you prefer explicit flags.

# --- VPS / SSH (required for provision; host required for manage:* unless TRISTATE_STATE_DIR is set) ---
TRISTATE_HOST=
TRISTATE_SSH_USER=root
TRISTATE_SSH_PORT=22
# Optional: path to private key (same as --ssh-identity)
# TRISTATE_SSH_IDENTITY=

# --- Secrets & Outline (required for provision) ---
TRISTATE_CORP_OVPN=./secrets/corporate.ovpn
# Optional: two-line user/pass file for OpenVPN (omit if not needed)
# TRISTATE_AUTH_FILE=./secrets/corporate.auth

# Outline / Shadowsocks upstreams (comma-separated ss://... or ssconf://...
# URIs; ssconf:// is resolved via HTTPS at provision time). Two or more
# endpoints are balanced across via Xray's routing balancer.
# Example:
# TRISTATE_OUTLINE_URIS=ss://BASE64CREDS@host1.example:8388,ssconf://host2.example/key.yaml
TRISTATE_OUTLINE_URIS=

# --- REALITY / inbound (optional; defaults match scripts) ---
TRISTATE_LISTEN_PORT=443
TRISTATE_SERVER_NAME=yandex.ru
TRISTATE_REALITY_DEST=yandex.ru:443
TRISTATE_CLIENT_NAME=laptop

# --- Paths ---
TRISTATE_INSTALL_DIR=/opt/tristate-relay
TRISTATE_STATE_ROOT=./state
# Optional: override computed state dir (default: ${TRISTATE_STATE_ROOT}/${TRISTATE_HOST})
# TRISTATE_STATE_DIR=
